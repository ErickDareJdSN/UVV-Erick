def funcao():
    soma = 0
    try:
        num = int(input("Digite o número a ser somado (entre 0 e 100): "))
        if num < 0 or num > 100:
            print("Número inválido! Digite um número entre 0 e 100.")
            return None
        for i in range(num + 1):
            soma += i
        print("A soma dos números de 0 até", num, "é:", soma)
        return soma
    except ValueError:
        print("Entrada inválida! Por favor, digite um número inteiro.")
        return None

funcao()