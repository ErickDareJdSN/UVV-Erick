def tabuada():
    while True:
        try:
            num = int(input("Digite o número para ver a tabuada (0 para sair): "))
            if num == 0:
                print("Programa encerrado.")
                return
            if num < 0 or num > 100:
                print("Número inválido! Digite um número entre 0 e 100.")
                continue
            for i in range(1, 11):
                print(f"{num} x {i} = {num * i}")
            print()
        except ValueError:
            print("Entrada inválida! Por favor, digite um número inteiro.")

tabuada()